# Backend API base URL — baked into the client bundle at build time by vite.config.ts.
# On Railway, set this variable to the backend's public domain reference:
#   VITE_API_BASE_URL=https://${{ crassus.RAILWAY_PUBLIC_DOMAIN }}/v1
#
# This file intentionally leaves the value empty so that the Railway build
# environment variable takes precedence. The fallback in vite.config.ts
# (http://localhost:8000/v1) is used only for local development builds.
VITE_API_BASE_URL=
