{
	"name": "crassus-web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"start": "node buld",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
